{
  "welcomeFile": "/project-portal/webapp/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/logout.html"
  },
  "routes": [
    {
      "source": "^/(governance|auth)/(.*)$",
      "target": "/$1/$2",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/logout.html$",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/(.*)$",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
