# -----------------------------------------------------------------------------
# NADEC E2E Delivery Governance — environment variables
# Copy to `.env` for local overrides (git-ignored). All are OPTIONAL locally.
# -----------------------------------------------------------------------------

# Auth strategy for srv/role-guard.js:
#   local  → app JWT (HS256) issued by /login after a bcrypt password check (default)
#   xsuaa  → validate SAP XSUAA / IAS Bearer tokens (used on BTP; see mta.yaml)
AUTH_MODE=local

# Secret used to sign / verify the app JWT. CHANGE IN PRODUCTION.
JWT_SECRET=e2e-governance-secret-key-change-in-production

# --- SuccessFactors (only needed when you want live SF lookups) --------------
# On BTP this is a bound BTP Destination (see mta.yaml → SF_DESTINATION_NAME).
SF_DESTINATION_NAME=SF_PRD_Raw
# Local direct-call fallback (Basic auth) — leave blank to disable SF locally:
# SF_API_URL=https://<sf-host>
# SF_USERNAME=<user>@<company>
# SF_PASSWORD=<password>
