{
  "name": "nadec-e2e-governance",
  "version": "0.1.0",
  "description": "NADEC E2E Delivery Governance — SAP CAP service (SQLite; HANA-ready)",
  "private": true,
  "dependencies": {
    "@cap-js/change-tracking": "^2.0.1",
    "@cap-js/hana": "^2.8.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap/cds": "^9",
    "@sap/xsenv": "^6.2.1",
    "@sap/xssec": "^4.13.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy:local": "cds deploy --to sqlite:db/e2e.db"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "custom",
        "impl": "srv/role-guard.js"
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/e2e.db"
        }
      }
    },
    "[production]": {
      "requires": {
        "db": {
          "kind": "hana"
        }
      }
    }
  }
}
